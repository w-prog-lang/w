// W uses Go's bitwise precedence, not C's: '&'/'<<'/'>>' bind like '*',
// '|'/'^' bind like '+', and all of them bind tighter than comparisons
fn main: int32 <- () {
    x := 5;
    a := x | 3 & 1;    // '&' first: 5 | (3 & 1) = 5
    b := 1 | 1 << 3;   // '<<' first: 1 | (1 << 3) = 9
    var c := 0;
    if (x & 4 == 4) {  // '(x & 4) == 4', not the C trap 'x & (4 == 4)'
        c = 1;
    }
    return a + b + c;  // 15
}
